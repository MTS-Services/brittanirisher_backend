// schema.prisma
// =============================================================
// Sports Event Management Platform — Prisma schema
// Derived strictly from the existing React frontend 
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------

enum Role {
  COUPLE
  VENDOR
  ADMIN
}

enum AccountStatus {
  ACTIVE
  PENDING_VERIFICATION
  SUSPENDED
  DEACTIVATED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum OtpPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  LOGIN_2FA
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
}

// -----------------------------------------------------------------
// AUTH / USERS
// -----------------------------------------------------------------

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  phone         String?
  passwordHash  String
  role          Role          @default(COUPLE)
  status        AccountStatus @default(PENDING_VERIFICATION)
  profileStep   Int           @default(1)
  isActive      Boolean       @default(true)
  emailVerified Boolean       @default(false)
  joinedAt      DateTime      @default(now())
  lastLoginAt   DateTime?
  avatarUrl     String?

  // Relations
  otpTokens     OtpToken[]
  sessions      Session[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  coupleProfile CoupleProfile?
  vendorProfile VendorProfile?

  @@index([role, status])
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String    @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId])
}

model OtpToken {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String
  purpose    OtpPurpose
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([userId, purpose])
}

// -----------------------------------------------------------------
// Admin Profile
// -----------------------------------------------------------------

model Category {
  id             String          @id @default(cuid())
  name           String          @unique
  slug           String          @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  coupleExpenses CoupleExpense[]
  vendorProfiles VendorProfile[]
}

model WeddingStyle {
  id             String          @id @default(cuid())
  name           String          @unique
  slug           String          @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  coupleProfiles CoupleProfile[]
}

model SubscriptionPlan {
  id              String               @id @default(uuid())
  planName        String
  sortDescription String?
  stripePriceId   String?
  validFor        String?
  priceMonthly    Decimal              @db.Decimal(10, 2)
  portfolioLimit  Int                  @default(10)
  featuresAllowed Json
  isDeleted       Boolean              @default(false)
  createdAt       DateTime             @default(now())
  subscriptions   VendorSubscription[]

  @@map("subscription_plans")
}

// -----------------------------------------------------------------
// Couple Profile
// -----------------------------------------------------------------

model CoupleProfile {
  id                     String                  @id @default(uuid())
  userId                 String                  @unique
  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                   String
  eventDate              DateTime?
  budget                 Decimal                 @db.Decimal(10, 2)
  expendBudget           Decimal                 @default(0) @db.Decimal(10, 2)
  remainingBudget        Decimal                 @default(0) @db.Decimal(10, 2)
  weldingStyleId         String?
  weldingStyle           WeddingStyle?           @relation(fields: [weldingStyleId], references: [id])
  weldingDate            DateTime?
  estimatedGuests        Int?
  location               String?
  phone                  String?
  profileImage           String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  coupleExpenses         CoupleExpense[]
  weddingDaySchedules    WeddingDaySchedule[]
  enquiries              Enquiry[]
  taskSections           TaskSection[]
  savedVendors           SavedVendor[]
  coupleTimelineSections CoupleTimelineSection[]

  @@map("couple_profiles")
}

model CoupleExpense {
  id String @id @default(uuid())

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  vendorName  String?
  vendorPhone String?
  vendorEmail String?

  amount Decimal @db.Decimal(10, 2)
  note   String? @db.Text

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  coupleProfile   CoupleProfile @relation(fields: [coupleProfileId], references: [id])
  coupleProfileId String

  @@index([coupleProfileId])
  @@index([categoryId])
  @@map("couple_expenses")
}

model TaskSection {
  id    String @id @default(uuid())
  title String
  order Int

  // Relations
  coupleProfileId String
  coupleProfile   CoupleProfile @relation(fields: [coupleProfileId], references: [id], onDelete: Cascade)
  tasks           CoupleTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([coupleProfileId, title])
}

model CoupleTask {
  id String @id @default(uuid())

  milestoneTitle String
  taskName       String
  isCompleted    Boolean @default(false)
  isCustom       Boolean @default(false)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  taskSection   TaskSection @relation(fields: [taskSectionId], references: [id], onDelete: Cascade)
  taskSectionId String

  @@map("couple_tasks")
}

model CoupleTimelineSection {
  id       String @id @default(uuid())
  category String
  order    Int

  // Relations
  coupleProfileId String
  coupleProfile   CoupleProfile        @relation(fields: [coupleProfileId], references: [id], onDelete: Cascade)
  tasks           CoupleTimelineTask[]
  note            String?              @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([coupleProfileId, category])
}

model CoupleTimelineTask {
  id String @id @default(uuid())

  phaseTitle String?
  taskName   String
  dueDate    DateTime?
  priority   String    @default("MEDIUM") // LOW, MEDIUM, HIGH
  taskNotes  String?   @db.Text

  isCompleted Boolean @default(false)
  isCustom    Boolean @default(false)

  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  coupleTimelineSection   CoupleTimelineSection @relation(fields: [coupleTimelineSectionId], references: [id])
  coupleTimelineSectionId String

  @@map("couple_timeline_tasks")
}

model WeddingDaySchedule {
  id              String        @id @default(uuid())
  coupleProfileId String
  coupleProfile   CoupleProfile @relation(fields: [coupleProfileId], references: [id], onDelete: Cascade)

  eventName String
  location  String
  startTime String

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("wedding_day_schedules")
}

model SavedVendor {
  id              String        @id @default(uuid())
  coupleProfileId String
  coupleProfile   CoupleProfile @relation(fields: [coupleProfileId], references: [id], onDelete: Cascade)

  vendorId String
  vendor   VendorProfile @relation(fields: [vendorId], references: [id])

  createdAt DateTime @default(now())

  @@map("saved_vendors")
}

// -----------------------------------------------------------------
// Vendor Profile
// -----------------------------------------------------------------

model VendorProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName        String
  location            String
  phone               String?
  highlightedServices String[]
  experienceYears     String?
  speciality          String?
  aboutMe             String?  @db.Text
  coverImage          String?

  currentSubscriptionId String?             @unique
  currentSubscription   VendorSubscription? @relation("CurrentActiveSub", fields: [currentSubscriptionId], references: [id], onDelete: SetNull)

  stripeCustomerId String?
  isVerified       Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  status           VendorStatus @default(PENDING)
  categoryId       String
  category         Category     @relation(fields: [categoryId], references: [id])

  packages        VendorPackage[]
  portfolioImages VendorPortfolio[]
  availabilities  VendorAvailability[]
  enquiries       Enquiry[]

  subscriptions VendorSubscription[] @relation("SubHistory")

  vendorBookings VendorBooking[]
  savedVendors   SavedVendor[]
  payments       Payment[]

  @@map("vendor_profiles")
}

// Vendor Portfolio Grid
model VendorPortfolio {
  id        String        @id @default(uuid())
  vendorId  String
  vendor    VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  mediaUrl  String
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())

  @@map("vendor_portfolios")
}

enum AvailabilityStatus {
  AVAILABLE
  UNAVAILABLE
  BOOKED
}

model VendorAvailability {
  id       String        @id @default(uuid())
  vendorId String
  vendor   VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  blockedDate DateTime
  status      AvailabilityStatus @default(BOOKED)

  note String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([vendorId, blockedDate])
  @@map("vendor_availabilities")
}

// enum AvailabilityStatus {
//   BOOKED
//   UNAVAILABLE
// }

// Leads Management
model Enquiry {
  id            String         @id @default(uuid())
  vendorId      String
  vendor        VendorProfile  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  profileId     String?
  coupleProfile CoupleProfile? @relation(fields: [profileId], references: [id])

  senderName  String
  senderPhone String
  senderEmail String
  message     String        @db.Text
  status      EnquiryStatus @default(NEW)
  createdAt   DateTime      @default(now())

  @@map("enquiries")
}

enum EnquiryStatus {
  NEW
  PENDING
  REPLIED
  IGNORED
  CONTRACTED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
}

enum PaymentStatus {
  SUCCESS
  PENDING
  FAILED
  REFUNDED
}

model VendorSubscription {
  id String @id @default(uuid())

  vendorId String
  vendor   VendorProfile @relation("SubHistory", fields: [vendorId], references: [id], onDelete: Cascade)

  planId               String
  plan                 SubscriptionPlan   @relation(fields: [planId], references: [id])
  status               SubscriptionStatus @default(ACTIVE)
  startsAt             DateTime           @default(now())
  stripeSubscriptionId String?            @unique
  endsAt               DateTime
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  payments             Payment[]

  currentForVendor VendorProfile? @relation("CurrentActiveSub")

  @@map("vendor_subscriptions")
}

model Payment {
  id             String              @id @default(uuid())
  vendorId       String
  vendor         VendorProfile       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  subscriptionId String?
  subscription   VendorSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  amount         Float
  currency       String        @default("USD")
  status         PaymentStatus @default(SUCCESS)
  stripeIntentId String?       @unique

  purchaseDate DateTime @default(now())
  createdAt    DateTime @default(now())

  @@map("payments")
}

model VendorPackage {
  id               String          @id @default(uuid())
  vendorId         String
  vendor           VendorProfile   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  packageName      String
  price            Decimal         @db.Decimal(10, 2)
  badge            String?
  shortDescription String?
  features         Json
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  vendorBookings   VendorBooking[]

  @@map("vendor_packages")
}

enum BookingStatus {
  PENDING
  BOOKED
  COMPLETED
  CANCELED
}

model VendorBooking {
  id String @id @default(uuid())

  vendorId String
  vendor   VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  coupleName  String
  email       String
  phone       String
  venueName   String
  location    String
  weddingDate DateTime
  price       Float

  packageId String
  package   VendorPackage @relation(fields: [packageId], references: [id])

  status BookingStatus @default(BOOKED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vendor_bookings")
}
