# ────────────────────────────────────────────────────────────────────
# KEEP CERTAIN FILES (using !)
# ────────────────────────────────────────────────────────────────────

# Keep example environment file
!.env.example

# Keep HTTP test files for API documentation
!**/*.test.http

# Keep README files
!**/README.md

# Keep necessary config files
!.eslintrc.js
!.prettierrc
!jest.config.js

# ====================================================================
# SECURITY REMINDER:
# Never commit sensitive information like:
# - Environment files (.env)
# - Database credentials  
# - JWT secrets
# - API keys
# - Certificates and private keys
# - User uploaded files
# ====================================================================