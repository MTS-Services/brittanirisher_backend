# ====================================================================
# McCann & Curran Property Management Platform - Environment Configuration
# ====================================================================
# Copy this file to .env and update with your actual values

# ────────────────────────────────────────────────────────────────────
# APPLICATION SETTINGS
# ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ────────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database?schema=public
DATABASE_URL="postgres://postgres:5sDUXspgcTOqNpBkvXtGSZ2C5jZDzzDdnJ7nmcHbYheg2mnt5V63XP27KlF1DzBt@187.127.164.72:5478/postgres"

# ────────────────────────────────────────────────────────────────────
# JWT AUTHENTICATION SETTINGS
# ────────────────────────────────────────────────────────────────────
# Generate strong random secrets (32+ characters)
# You can use: openssl rand -hex 32
JWT_SECRET="your-super-secure-jwt-secret-key-here-minimum-32-characters"
JWT_REFRESH_SECRET="your-super-secure-refresh-secret-key-here-minimum-32-characters"

# Token expiration times
JWT_ACCESS_EXPIRE="1d"
JWT_REFRESH_EXPIRE="7d"

# ────────────────────────────────────────────────────────────────────
# SECURITY SETTINGS
# ────────────────────────────────────────────────────────────────────
# Password hashing rounds (10-12 recommended for production)
BCRYPT_ROUNDS=12

# ────────────────────────────────────────────────────────────────────
# CORS CONFIGURATION
# ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,https://yourdomain.com"

# ────────────────────────────────────────────────────────────────────
# RATE LIMITING
# ────────────────────────────────────────────────────────────────────
# 15 minutes window
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ────────────────────────────────────────────────────────────────────
# FILE UPLOAD SETTINGS
# ────────────────────────────────────────────────────────────────────
# Maximum file size in bytes (5MB = 5242880)
MAX_FILE_SIZE=5242880
# Upload directory path
UPLOAD_PATH="./uploads"

# ────────────────────────────────────────────────────────────────────
# LOGGING CONFIGURATION
# ────────────────────────────────────────────────────────────────────
# Log levels: error, warn, info, debug
LOG_LEVEL=info


# ────────────────────────────────────────────────────────────────────
# PRODUCTION SETTINGS (uncomment and configure for production)
# ────────────────────────────────────────────────────────────────────

# Database connection for production
# DATABASE_URL="postgresql://prod_user:prod_password@prod_host:5432/property_management_prod"

# Strong production JWT secrets
# JWT_SECRET="your-production-jwt-secret-minimum-64-characters-long-random-string"
# JWT_REFRESH_SECRET="your-production-refresh-secret-minimum-64-characters-long-random-string"

# Production CORS
# ALLOWED_ORIGINS="https://yourdomain.com,https://app.yourdomain.com"

# Stricter rate limiting for production
# RATE_LIMIT_MAX_REQUESTS=50

# Production logging
# LOG_LEVEL=warn

# ────────────────────────────────────────────────────────────────────
# OPTIONAL: EMAIL CONFIGURATION (when implementing email features)
# ────────────────────────────────────────────────────────────────────

# SMTP settings for email notifications
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# FROM_EMAIL="noreply@mccannandcurran.ie"
# FROM_NAME="McCann & Curran"

# ────────────────────────────────────────────────────────────────────
# OPTIONAL: CLOUD STORAGE (when implementing file storage)
# ────────────────────────────────────────────────────────────────────

# AWS S3 Configuration
# AWS_REGION="eu-west-1"
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_S3_BUCKET="your-bucket-name"

# Cloudinary Configuration (alternative)
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"

# ────────────────────────────────────────────────────────────────────
# OPTIONAL: MONITORING & ANALYTICS
# ────────────────────────────────────────────────────────────────────

# Sentry for error tracking
# SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# Application monitoring
# NEW_RELIC_LICENSE_KEY="your-new-relic-license-key"
# NEW_RELIC_APP_NAME="McCann & Curran Property API"

# ────────────────────────────────────────────────────────────────────
# DEVELOPMENT SETTINGS
# ────────────────────────────────────────────────────────────────────

# Set to true to enable detailed query logging in development
# PRISMA_DEBUG=true

# Set to true to enable debug logs
# DEBUG=true

# ====================================================================
# IMPORTANT SECURITY NOTES:
# 1. Never commit this file with real credentials to version control
# 2. Use strong, unique secrets for JWT tokens (minimum 32 chars)
# 3. Use environment variables in production deployment
# 4. Regularly rotate JWT secrets and database passwords
# 5. Use HTTPS in production
# ====================================================================